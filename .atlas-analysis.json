  "keyFeatures": [
    "AI-powered metadata tag generation using OpenRouter API",
    "Hybrid OCR system (Tesseract + EasyOCR) for scanned documents",
    "Real-time batch processing with WebSocket progress updates",
    "Support for 80+ languages including all Indian languages",
    "Exclusion list filtering for improved tag specificity",
    "URL-based document processing (CloudFront, S3, public URLs)",
    "User authentication and document history tracking",
    "CSV import/export with customizable column mapping"
  ],
  "publicApiSurface": [
    "POST /api/single/process - Process single PDF document",
    "GET /api/single/preview - Preview PDF from URL",
    "WebSocket /api/batch/ws/{job_id} - Real-time batch processing",
    "POST /api/batch/validate-paths - Validate file paths",
    "POST /api/batch/process - Legacy batch processing",
    "GET /api/batch/template - Get CSV template",
    "POST /api/auth/register - User registration",
    "POST /api/auth/login - User authentication",
    "POST /api/auth/refresh - Refresh access token",
    "GET /api/auth/me - Get current user",
    "GET /api/health - Health check endpoint"
  ]
